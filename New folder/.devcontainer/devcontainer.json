{
  "name": "AGent Sweeps Dev",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "customizations": {
    "vscode": {
      "extensions": [
        "HoangGiaSeo.agent-sweeps"
      ],
      "settings": {
        "agentSweeps.defaultAiProvider": "ollama"
      }
    }
  },
  "postCreateCommand": "cd agent-sweeps-vscode && npm install",
  "features": {
    "ghcr.io/devcontainers/features/rust:1": {}
  }
}
